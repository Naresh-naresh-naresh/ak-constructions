# Copy to .env.local and fill in real values (see docs/ADMIN-SETUP.md).
# .env.local is gitignored — never commit real secrets.

PROJECTS_TABLE_NAME=ak-constructions-projects
# ap-southeast-2 (Sydney) because this client's Amplify app already lives there —
# a fresh client deployment should use ap-south-1 (Mumbai) instead. See docs/ADMIN-SETUP.md
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

NEXTAUTH_URL=http://localhost:3005
NEXTAUTH_SECRET=
ADMIN_USERNAME=
# Escape every $ as \$ here (Next.js expands $ in .env files) — see docs/ADMIN-SETUP.md
ADMIN_PASSWORD_HASH=
